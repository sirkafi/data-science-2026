    {
      "cell_type": "code",
      "source": [
        "np.random.seed(42)\n",
        "\n",
        "n = 300\n",
        "\n",
        "pengalaman = np.random.uniform(0, 20, n)\n",
        "\n",
        "edu = np.random.choice(\n",
        "    [0, 1, 2],\n",
        "    n\n",
        ")\n",
        "\n",
        "kota = np.random.choice(\n",
        "    ['Jakarta', 'Surabaya', 'Bandung'],\n",
        "    n\n",
        ")\n",
        "\n",
        "gaji = (\n",
        "    3.0\n",
        "    + 2.2 * pengalaman\n",
        "    + 1.5 * edu\n",
        "    + np.where(kota == 'Jakarta', 4.0, 0)\n",
        "    + np.random.normal(0, 2, n)\n",
        ")\n",
        "\n",
        "df = pd.DataFrame({\n",
        "    'pengalaman': pengalaman,\n",
        "    'edu': edu,\n",
        "    'kota': kota,\n",
        "    'gaji': gaji\n",
        "})\n",
        "\n",
        "print(\"=== Shape Dataset ===\")\n",
        "print(df.shape)\n",
        "\n",
        "print(\"\\n=== Data Teratas ===\")\n",
        "print(df.head())"
      ],
